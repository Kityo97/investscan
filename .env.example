# InvestScan – API kulcsok
# Másold ezt .env névvel és töltsd ki a kulcsokat!

# Financial Modeling Prep – https://financialmodelingprep.com/register
# Ingyenes: 250 req/nap
FMP_API_KEY=ide_a_fmp_kulcsod

# Alpha Vantage – https://www.alphavantage.co/support/#api-key
# Ingyenes: 25 req/nap
ALPHA_VANTAGE_KEY=ide_az_av_kulcsod

# FRED API – https://fred.stlouisfed.org/docs/api/api_key.html
# Teljesen ingyenes, korlátlan
FRED_API_KEY=ide_a_fred_kulcsod

# Adatbázis (opcionális – alapértelmezett: investscan.db az app mappájában)
# DB_PATH=investscan.db
